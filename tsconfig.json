{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["node"],
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src"],
  "exclude": ["tests", "dist"]
}
